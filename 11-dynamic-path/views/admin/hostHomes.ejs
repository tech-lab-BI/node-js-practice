        <ul class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
            <% homes.forEach((home) => {%>
                <%- include('../partials/homeList', {home: home})%>
                        <a href="#" class="mt-8">
                        <button
                            class="w-20 bg-red-500 text-white py-1 rounded-lg font-semibold hover:bg-red-600 transition"
                        >
                            Delete
                        </button>
                        </a>
                        <a href="#" class="mt-6">
                        <button
                            class="w-20 bg-blue-500 text-white py-1 rounded-lg font-semibold hover:bg-blue-600 transition"
                        >
                            Edit
                        </button>
                        </a>
                    </div>
                </li>
            <%});%>
